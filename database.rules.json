{
  "rules": {
    ".read": false,
    ".write": false,
    "deviceRegistry": {
      ".read": false,
      "$uid": {
        ".write": false,
        ".validate": "newData.isBoolean()"
      }
    },
    "telemetry": {
      ".read": "auth != null",
      "$powerbankId": {
        ".write": "auth != null && root.child('deviceRegistry').child(auth.uid).val() === true",
        ".validate": "newData.hasChildren(['online', 'batteryLevel', 'lastSeenAt'])"
      }
    }
  }
}
